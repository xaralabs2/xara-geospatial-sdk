{
  "name": "@xara/geospatial-client",
  "version": "1.0.0",
  "description": "Official TypeScript/JavaScript SDK for the Xara Geospatial Engine API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "geospatial",
    "gis",
    "postgis",
    "h3",
    "spatial",
    "parcel",
    "gpid",
    "xara"
  ],
  "author": "Xara Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xaralabs2/xara-geospatial-sdk.git"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
